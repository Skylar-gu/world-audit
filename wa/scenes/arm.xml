<mujoco model="arm">
  <option timestep="0.002" integrator="Euler" solver="Newton" tolerance="0" iterations="30"/>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="0.9 0.9 0.9"/>
    <geom name="floor" type="plane" size="1 1 0.02" rgba="0.5 0.5 0.55 1"/>

    <body name="base" pos="0 0 0.8">
      <geom name="base_geom" type="sphere" size="0.03" rgba="0.2 0.2 0.25 1"/>
      <body name="link_1" pos="0 0 0">
        <joint name="j1" type="hinge" axis="0 1 0" damping="0.05"/>
        <geom name="link_1_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.02"
              mass="0.4" rgba="0.7 0.3 0.3 1"/>
        <body name="link_2" pos="0 0 -0.2">
          <joint name="j2" type="hinge" axis="0 1 0" damping="0.05"/>
          <geom name="link_2_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.018"
                mass="0.3" rgba="0.3 0.7 0.3 1"/>
          <body name="link_3" pos="0 0 -0.2">
            <joint name="j3" type="hinge" axis="0 1 0" damping="0.05"/>
            <geom name="link_3_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.016"
                  mass="0.2" rgba="0.3 0.3 0.7 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <sensor>
    <framepos name="link_1.pos" objtype="body" objname="link_1"/>
    <framelinvel name="link_1.vel" objtype="body" objname="link_1"/>
    <framepos name="link_2.pos" objtype="body" objname="link_2"/>
    <framelinvel name="link_2.vel" objtype="body" objname="link_2"/>
    <framepos name="link_3.pos" objtype="body" objname="link_3"/>
    <framelinvel name="link_3.vel" objtype="body" objname="link_3"/>
  </sensor>
</mujoco>

<mujoco model="blocks">
  <option timestep="0.002" integrator="Euler" solver="Newton" tolerance="0" iterations="30"/>

  <default>
    <geom friction="0.8 0.005 0.0001" solref="0.004 1" solimp="0.95 0.99 0.001"/>
  </default>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="0.9 0.9 0.9"/>
    <geom name="floor" type="plane" size="1 1 0.02" rgba="0.5 0.5 0.55 1"/>

    <body name="block_0" pos="0 0 0.04">
      <freejoint name="block_0_free"/>
      <geom name="block_0_geom" type="box" size="0.04 0.04 0.04" mass="0.5" rgba="0.8 0.3 0.2 1"/>
    </body>
    <body name="block_1" pos="0 0 0.12">
      <freejoint name="block_1_free"/>
      <geom name="block_1_geom" type="box" size="0.04 0.04 0.04" mass="0.5" rgba="0.85 0.55 0.15 1"/>
    </body>
    <body name="block_2" pos="0 0 0.20">
      <freejoint name="block_2_free"/>
      <geom name="block_2_geom" type="box" size="0.04 0.04 0.04" mass="0.5" rgba="0.85 0.8 0.2 1"/>
    </body>
    <body name="block_3" pos="0 0 0.28">
      <freejoint name="block_3_free"/>
      <geom name="block_3_geom" type="box" size="0.04 0.04 0.04" mass="0.5" rgba="0.3 0.6 0.3 1"/>
    </body>
  </worldbody>

  <sensor>
    <framepos name="block_0.pos" objtype="body" objname="block_0"/>
    <framelinvel name="block_0.vel" objtype="body" objname="block_0"/>
    <framepos name="block_1.pos" objtype="body" objname="block_1"/>
    <framelinvel name="block_1.vel" objtype="body" objname="block_1"/>
    <framepos name="block_2.pos" objtype="body" objname="block_2"/>
    <framelinvel name="block_2.vel" objtype="body" objname="block_2"/>
    <framepos name="block_3.pos" objtype="body" objname="block_3"/>
    <framelinvel name="block_3.vel" objtype="body" objname="block_3"/>
  </sensor>
</mujoco>
